# DeepEye Backend – Environment Variables
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info
WORKERS=1

# CORS – comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# vLLM vision model server
VLLM_BASE_URL=https://vllm.portalgrup.ai/art
VLLM_API_KEY=your-api-key-here
VLLM_MODEL=
VLLM_MAX_TOKENS=512
VLLM_TEMPERATURE=0.2
VLLM_TIMEOUT=60

# DeepFace settings
DEEPFACE_MODEL=ArcFace
DEEPFACE_DETECTOR=retinaface
SIMILARITY_THRESHOLD=0.40

# ChromaDB
CHROMA_PATH=./chroma_data
